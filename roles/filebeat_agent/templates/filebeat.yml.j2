filebeat.inputs:
  - type: filestream
    enabled: true
    paths:
{% for path in filebeat_log_paths %}
      - {{ path }}
{% endfor %}
    fields:
      log_type: syslog
    fields_under_root: true

output.logstash:
  hosts:
    - "{{ filebeat_logstash_host }}:{{ filebeat_logstash_port }}"

setup.template.enabled: false
setup.ilm.enabled: false
