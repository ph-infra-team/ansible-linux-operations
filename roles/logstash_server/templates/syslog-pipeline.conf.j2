input {
  beats {
    port => {{ logstash_listen_port }}
  }
}

filter {
  if "syslog" in [log_type] {
    grok {
      match => { "message" => "%{SYSLOGLINE}" }
    }
    date {
      match => [ "timestamp", "MMM  d HH:mm:ss", "MMM dd HH:mm:ss" ]
      target => "@timestamp"
    }
  }
}

output {
  elasticsearch {
    hosts => ["{{ logstash_elasticsearch_host }}"]
    index => "{{ logstash_output_index }}"
  }
}
